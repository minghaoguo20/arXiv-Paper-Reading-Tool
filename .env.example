# Translation API Configuration
# =============================

# Translation API Key (Required, unless using test mode with --model x)
# Obtain your API key from your translation service provider
MY_API_KEY=your-api-key-here

# API Endpoint URL (Optional)
# Custom API endpoint that is compatible with OpenAI format
# Default: https://api.openai.com/v1/chat/completions
MY_API_URL=https://api.openai.com/v1/chat/completions

# Usage Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace 'your-api-key-here' with your actual API key
# 3. Modify MY_API_URL if you're using a different service
# 4. The .env file will be automatically loaded by the application
